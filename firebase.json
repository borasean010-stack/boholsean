{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "blueprint.md",
      "GEMINI.md",
      "README.md",
      "main.js",
      "style.css"
    ],
    "rewrites": [
      {
        "source": "/quote",
        "destination": "/quote.html"
      },
      {
        "source": "/bohol-admin",
        "destination": "/bohol-admin.html"
      },
      {
        "source": "/admin-quote-maker",
        "destination": "/admin-quote-maker.html"
      },
      {
        "source": "/bohol-voucher",
        "destination": "/bohol-voucher.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}